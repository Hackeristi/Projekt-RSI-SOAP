<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="authOverlay" alignment="CENTER" spacing="20.0" style="-fx-background-color: #121212;"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="pl.rsi.cinema.BookingController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>
    <children>
        <Label style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;"
            text="Logowanie" />

        <VBox spacing="5.0">
            <Label style="-fx-text-fill: #aaaaaa;" text="E-mail" />
            <TextField fx:id="loginEmail"
                style="-fx-background-color: #1a1a1a; -fx-border-color: #313131; -fx-text-fill: white;" />
        </VBox>

        <VBox spacing="5.0">
            <Label style="-fx-text-fill: #aaaaaa;" text="Hasło" />
            <PasswordField fx:id="loginPassword"
                style="-fx-background-color: #1a1a1a; -fx-border-color: #313131; -fx-text-fill: white;" />
        </VBox>

        <Button maxWidth="Infinity" onAction="#handleLogin"
            style="-fx-background-color: #0078D7; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10;"
            text="Zaloguj się" />
        <HBox alignment="CENTER" prefHeight="0.0" prefWidth="200.0">
            <children>
                <Label alignment="CENTER" prefHeight="5.0" prefWidth="88.0" text="Nie masz konta?"
                    textFill="WHITE">
                    <font>
                        <Font name="Franklin Gothic Book" size="12.0" />
                    </font>
                </Label>

                <Hyperlink fx:id="registerLink" alignment="CENTER" onAction="#showRegisterForm"
                    prefHeight="9.0" prefWidth="79.0" style="-fx-font-size: 11;"
                    text=" Zarejestruj się" textFill="#4fb3ff" />
            </children>
        </HBox>
    </children>
</VBox>