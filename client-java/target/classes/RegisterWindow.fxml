<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="authOverlay" alignment="CENTER" spacing="15.0" style="-fx-background-color: #121212;"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="pl.rsi.cinema.BookingController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>
    <children>
        <Label style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;"
            text="Stwórz Konto">
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </Label>

        <VBox spacing="5.0">
            <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 11;" text="Imię i Nazwisko" />
            <TextField fx:id="registerName"
                style="-fx-background-color: #1a1a1a; -fx-border-color: #313131; -fx-border-radius: 5; -fx-text-fill: white; -fx-padding: 8;" />
        </VBox>

        <VBox spacing="5.0">
            <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 11;" text="Adres E-mail" />
            <TextField fx:id="registerEmail"
                style="-fx-background-color: #1a1a1a; -fx-border-color: #313131; -fx-border-radius: 5; -fx-text-fill: white; -fx-padding: 8;" />
        </VBox>

        <VBox spacing="5.0">
            <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 11;" text="Hasło" />
            <PasswordField fx:id="registerPassword"
                style="-fx-background-color: #1a1a1a; -fx-border-color: #313131; -fx-border-radius: 5; -fx-text-fill: white; -fx-padding: 8;" />
        </VBox>

        <VBox spacing="5.0">
            <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 11;" text="Powtórz Hasło" />
            <PasswordField fx:id="registerConfirmPassword"
                style="-fx-background-color: #1a1a1a; -fx-border-color: #313131; -fx-border-radius: 5; -fx-text-fill: white; -fx-padding: 8;" />
        </VBox>

        <Button maxWidth="Infinity" onAction="#handleRegister"
            style="-fx-background-color: #0078D7; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 5;"
            text="Zarejestruj się">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Button>
        <HBox alignment="CENTER" prefHeight="0.0" prefWidth="200.0">
            <children>
                <Label alignment="CENTER" text="Masz już konto? " textFill="WHITE" />

                <Hyperlink fx:id="loginLink" alignment="CENTER" onAction="#showLoginForm"
                    style="-fx-font-size: 11; -fx-underline: false;" text="Zaloguj się"
                    textFill="#54b8ff" />
            </children>
        </HBox>
    </children>
</VBox>